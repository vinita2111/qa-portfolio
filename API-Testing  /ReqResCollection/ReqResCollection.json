        {
          "name": "List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// fetch the json data\r",
                  "var jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "     pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Correct Page Name\", function () {\r",
                  "  //  var jsonData = pm.response.json();\r",
                  "         pm.expect(jsonData.page).to.eql(2);\r",
                  "});\r",
                  " pm.test(\"Correct Entry Per Page\", function () {\r",
                  "         pm.expect(jsonData.per_page).to.eql(6);\r",
                  "});  \r",
                  " pm.test(\"Total Entry\", function () {\r",
                  "           pm.expect(jsonData.total).to.eql(12);\r",
                  "});  \r",
                  " pm.test(\"Total Pages\", function () {\r",
                  "         pm.expect(jsonData.total_pages).to.eql(2);\r",
                  "});  \r",
                  "\r",
                  "//To fetch and check array data element\r",
                  "pm.test(\"Correct Id\", function(){\r",
                  "    pm.expect(jsonData.data[0].id).to.eql(7);\r",
                  "});\r",
                  "\r",
                  "//Retrieving or fetching array json response data and checking for if any user exist\r",
                  "\r",
                  "pm.test(\"Check if a user with the first name'George' exists\",function(){\r",
                  "\r",
                  "  //Extract the data array\r",
                  "    const dataArray =jsonData.data;\r",
                  "\r",
                  "  // Initiaize a fag t check if 'George' exits\r",
                  "     let georgeExists = false;\r",
                  "\r",
                  "     //Loop through the data array\r",
                  "\r",
                  "     for(let i=0;i<dataArray.length;i++){\r",
                  "        if(dataArray[i].first_name===\"George\"){\r",
                  "\r",
                  "            georgeExists=true;\r",
                  "            break;\r",
                  "        }\r",
                  "        \r",
                  "       \r",
                  "     }\r",
                  "     pm.expect(georgeExists).to.be.true;\r",
                  "\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
